model HomeSlider {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  @@map("home_slider")
}

model notice {
  id        String   @id @default(cuid())
  text   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("notices")
}

model HeroImageText {
  id        String   @id @default(cuid())
  image     String
  name      String?
  title     String?
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@map("hero_image_text")
}

model AboutSection {
  id        String   @id @default(cuid())
  image     String
  name      String?
  title     String?
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@map("about_section")
}
