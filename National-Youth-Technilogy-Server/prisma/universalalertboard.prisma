model TaskData {
  id        String   @id @default(cuid())
  title     String
  link      String
  text      String
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompleteNewData {
  id        String   @id @default(cuid())
  title     String
  text      String
  date      String
  pdfUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

 
  model SendPublicStudent {
  id        String   @id @default(cuid())
  title     String
  text      String
  date      String
  pdfUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}